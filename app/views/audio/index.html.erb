<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  .audio-page {
    min-height: 100vh;
    background: #c4d4e8;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #0d0f1a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 1.5rem;
  }

  .audio-inner {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 1rem;
    border: 1.5px solid #0d0f1a;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d0f1a;
  }

  .audio-heading {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .audio-heading h1 {
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0d0f1a;
  }

  .audio-heading p {
    font-size: 1rem;
    font-weight: 400;
    color: #6b6e84;
    line-height: 1.6;
  }

  .new-song-card {
    width: 100%;
    display: block;
    text-decoration: none;
    color: inherit;
    background: #ffffff;
    border: 1.5px solid #e2e2ec;
    border-radius: 20px;
    padding: 1.5rem 1.25rem;
    text-align: left;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  .new-song-card:hover {
    box-shadow: 0 8px 28px rgba(80, 80, 140, 0.13);
    transform: translateY(-2px);
  }

  .card-icon {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: #ededf6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0d0f1a;
    margin-bottom: 0.4rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: #6b6e84;
    line-height: 1.55;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #5858c8;
  }

  .recent-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .recent-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9b9db8;
  }

  .song-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .song-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: #ffffff;
    border: 1.5px solid #e2e2ec;
    border-radius: 12px;
    gap: 1rem;
    text-decoration: none;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .song-row:hover {
    box-shadow: 0 4px 16px rgba(80, 80, 140, 0.1);
    transform: translateY(-1px);
  }

  .song-slug {
    font-size: 0.9rem;
    font-weight: 600;
    color: #5858c8;
  }

  .song-date {
    font-size: 0.75rem;
    color: #9b9db8;
    white-space: nowrap;
  }

  .empty {
    font-size: 0.85rem;
    color: #9b9db8;
    text-align: center;
    padding: 1.25rem;
    background: #ffffff;
    border: 1.5px solid #e2e2ec;
    border-radius: 12px;
  }

  .back-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: #9b9db8;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .back-link:hover { color: #5858c8; }
</style>

<div class="audio-page">
  <div class="audio-inner">

    <div class="audio-heading">
      <h1>Make some sounds.</h1>
      <p>A 12-note, 16-step browser sequencer. <br>Make some music and collaborate in real time.</p>
    </div>

    <%= link_to audio_new_path, class: "new-song-card" do %>
      <div class="card-icon">🎛️</div>
      <div class="card-title">New Song</div>
      <p class="card-desc">Open the sequencer and start building a beat from scratch.</p>
      <span class="card-link">Start →</span>
    <% end %>

    <% if @recent_songs.any? %>
      <div class="recent-section">
        <div class="recent-label">Recent Songs</div>
        <div class="song-list">
          <% @recent_songs.each do |song| %>
            <%= link_to audio_song_path(song.slug), class: "song-row" do %>
              <span class="song-slug"><%= song.slug %></span>
              <span class="song-date"><%= song.created_at.strftime('%b %d, %Y') %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= link_to '← Back', root_path, class: 'back-link' %>

  </div>
</div>
