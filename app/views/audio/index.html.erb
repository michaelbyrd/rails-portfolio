<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #111827;
    color: #e5e7eb;
    font-family: 'Courier New', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem;
    gap: 2.5rem;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    max-width: 520px;
  }

  .hero h1 {
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    color: #e5e7eb;
    text-transform: uppercase;
  }

  .hero p {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.7;
  }

  .hero p strong {
    color: #9ca3af;
  }

  .new-btn {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.6rem 2rem;
    background: #10b981;
    color: #fff;
    font-family: inherit;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-decoration: none;
    border-radius: 4px;
    transition: filter 0.1s;
  }
  .new-btn:hover { filter: brightness(1.15); }

  .divider {
    width: 100%;
    max-width: 560px;
    border: none;
    border-top: 1px solid #1f2937;
  }

  .recent {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .recent h2 {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    color: #4b5563;
    text-transform: uppercase;
  }

  .song-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .song-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    background: #1f2937;
    border-radius: 4px;
    border: 1px solid #374151;
    gap: 1rem;
  }

  .song-slug {
    color: #818cf8;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  .song-slug:hover { color: #a5b4fc; }

  .song-date {
    font-size: 0.7rem;
    color: #4b5563;
    white-space: nowrap;
  }

  .empty {
    font-size: 0.8rem;
    color: #374151;
    text-align: center;
    padding: 1rem;
  }
</style>

<div class="hero">
  <h1>Step Sequencer</h1>
  <p>
    A 12-note, 16-step browser sequencer built with <strong>Tone.js</strong>.<br>
    Create a song, share the link, and <strong>collaborate in real time</strong> — changes sync instantly to anyone with the URL.
  </p>
  <%= link_to 'NEW SONG →', audio_new_path, class: 'new-btn' %>
</div>

<hr class="divider">

<div class="recent">
  <h2>Recent Songs</h2>

  <% if @recent_songs.any? %>
    <div class="song-list">
      <% @recent_songs.each do |song| %>
        <div class="song-row">
          <%= link_to song.slug, audio_song_path(song.slug), class: 'song-slug' %>
          <span class="song-date"><%= song.created_at.strftime('%b %d, %Y') %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty">no songs yet — make one!</div>
  <% end %>
</div>