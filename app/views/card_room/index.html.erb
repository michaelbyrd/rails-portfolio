<div class="max-w-2xl mx-auto py-16 px-4">
  <h1 class="text-3xl font-bold mb-2">Card Room</h1>
  <p class="text-gray-400 mb-8">No Limit Hold'em</p>

  <div class="space-y-3">
    <% @tables.each do |table| %>
      <% seated = table.state['seats'].reject { |s| s['status'] == 'empty' }.count %>
      <a href="<%= card_room_table_path(table.slug) %>"
         class="flex items-center justify-between bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 hover:border-blue-500 transition-colors">
        <div>
          <div class="font-semibold text-lg"><%= table.name %></div>
          <div class="text-sm text-gray-400"><%= seated %>/<%= table.max_seats %> seats taken</div>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm <%= table.state['status'] == 'playing' ? 'text-green-400' : 'text-gray-500' %>">
            <%= table.state['status'] == 'playing' ? 'Hand in progress' : 'Waiting' %>
          </span>
          <span class="text-gray-600">→</span>
        </div>
      </a>
    <% end %>
  </div>
</div>
