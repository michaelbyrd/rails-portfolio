<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css/github-markdown-light.css">

<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #c8d8c4 !important;
    color: #0d0f1a;
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4rem 1.5rem;
    gap: 1.25rem;
  }

  .page-header {
    width: 100%;
    max-width: 680px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: #6b7280;
    text-decoration: none;
  }
  .back-link:hover { color: #0d0f1a; }

  .github-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: #0d0f1a;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .github-link:hover { opacity: 0.6; }

  .readme {
    width: 100%;
    max-width: 680px;
    background: #fff;
    border: 1.5px solid #b4c8b0;
    border-radius: 16px;
    padding: 2rem 2.25rem;
  }
</style>

<div class="page-header">
  <%= link_to '← Back', root_path, class: 'back-link' %>
  <%= link_to 'View this work on GitHub', @github_url, class: 'github-link', target: '_blank', rel: 'noopener' %>
</div>

<div class="readme">
  <div class="markdown-body" id="readme-content"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  const markdown = <%= raw @readme_markdown.to_json %>;
  document.getElementById('readme-content').innerHTML = marked.parse(markdown);
</script>
