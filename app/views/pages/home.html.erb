<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  .portfolio-page {
    min-height: 100vh;
    background: #ededf6;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #0d0f1a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 1.5rem;
  }

  .portfolio-inner {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
    position: relative;
  }

  /* ── Section pill badge ── */
  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 1rem;
    border: 1.5px solid #0d0f1a;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d0f1a;
  }

  /* ── Heading ── */
  .portfolio-heading {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .portfolio-heading h1 {
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0d0f1a;
  }

  .portfolio-heading p {
    font-size: 1rem;
    font-weight: 400;
    color: #6b6e84;
    line-height: 1.6;
  }

  /* ── Project cards ── */
  .project-grid {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 480px) {
    .project-grid { grid-template-columns: 1fr; }
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1.5px solid transparent;
    border-radius: 20px;
    padding: 1.5rem 1.25rem;
    text-align: left;
    position: relative;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  .project-card:hover {
    box-shadow: 0 8px 28px rgba(80, 80, 140, 0.13);
    transform: translateY(-2px);
  }

  .card-audio    { background: #c4d4e8; border-color: #afc4dc; }
  .card-cardroom { background: #e8b4a0; border-color: #d8a490; }
  .card-ctci     { background: #c8d8c4; border-color: #b4c8b0; }

  .card-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.9rem;
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0d0f1a;
    margin-bottom: 0.4rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: #6b6e84;
    line-height: 1.55;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #5858c8;
  }
</style>

<div class="portfolio-page">
  <div class="portfolio-inner">

    <div class="portfolio-heading">
      <h1>Building in public.</h1>
      <p>Personal projects I'm building as I learn to work with AI.<br>Treat it like a beta and enjoy!</p>
    </div>

    <div class="project-grid">

      <%= link_to audio_path, class: "project-card card-audio" do %>
        <div class="card-icon">🎛️</div>
        <div class="card-title">Step Sequencer</div>
        <p class="card-desc">A 12-note, 16-step browser sequencer. Create a beat and jam in real time.</p>
        <span class="card-link">Open →</span>
      <% end %>

      <%= link_to card_room_path, class: "project-card card-cardroom" do %>
        <div class="card-icon">🃏</div>
        <div class="card-title">Card Room</div>
        <p class="card-desc">Multiplayer No-Limit Hold'em. Sit down, add bots, play live over WebSockets.</p>
        <span class="card-link">Open →</span>
      <% end %>

      <%= link_to ctci_path, class: "project-card card-ctci" do %>
        <div class="card-icon">📖</div>
        <div class="card-title">CTCI</div>
        <p class="card-desc">Cracking the Coding Interview — problems and solutions organized by chapter.</p>
        <span class="card-link">Open →</span>
      <% end %>

    </div>

  </div>
</div>
